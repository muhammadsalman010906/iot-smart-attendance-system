//--- Time Configuration ---
int timezone = 5 * 3600;
int time_dst = 0;
unsigned long previousMillis1 = 0;
unsigned long previousMillis2 = 0;

//--- Web Access Configration ---
String getData, Link;
String OldCardID = "";
String URL = "http://docit.tmuc.edu.pk/docit/webproj/rfid/getdata.php";


// ================================================= S E R V I C E S   I N I T I A L I Z A T I O N   S T A R T S =================================================

// ================================================= S E T U P   I N I T I A L I Z A T I O N   S T A R T S =================================================

void setup() {
  Serial.begin(115200);
  while (!Serial);
  delay(1000);

//--- RFID Process Initialization ---  
  SPI.begin(RF_SCK_PIN, RF_MISO_PIN, RF_MOSI_PIN);
  for (uint8_t RF_Reader = 0; RF_Reader < RFID_Readers; RF_Reader++) {
    mfrc522[RF_Reader].PCD_Init(sdaPins[RF_Reader], RF_RST_PIN);
    Serial.print(F("RF Reader "));
    Serial.print(RF_Reader);
    Serial.print(F(": "));
    mfrc522[RF_Reader].PCD_DumpVersionToSerial();
    // - Add Notification that Readers are working on OLED
  }

//--- OLED Display Initialization ---
  if(!display.begin(0x3C, true)) { // Address 0x3D for 128x64
    Serial.println(F("SH1106 allocation failed"));
    for(;;); // Don't proceed, loop forever
  }  
  
  // Displaying Startup Logos
  display.clearDisplay();
  display.drawBitmap( 0, 0, embTMUC_bits, embTMUC_width, embTMUC_height, SH110X_WHITE);
  display.display();
  delay(2000); // Pause for 2 seconds
  display.clearDisplay();
  display.drawBitmap( 0, 0, logoTMUC_bits, logoTMUC_width, logoTMUC_height, SH110X_WHITE);
  display.display();
  delay(2000); // Pause for 2 seconds
  display.clearDisplay();
  display.drawBitmap( 0, 0, logoDoCIT_bits, logoDoCIT_width, logoDoCIT_height, SH110X_WHITE);
  display.display();
  delay(2000); // Pause for 2 seconds
  display.clearDisplay();
  pinMode(Relay, OUTPUT);
  digitalWrite(Relay, LOW);
  delay(1000);
  digitalWrite(Relay, HIGH);
  delay(1000);
  connectToWiFi();
  configTime(timezone, time_dst, "pool.ntp.org","time.nist.gov");
}

// ================================================= S E T U P   I N I T I A L I Z A T I O N   E N D S =================================================

// ================================================= L O O P   I N I T I A L I Z A T I O N   S T A R T S =================================================
void loop() {
  if(!WiFi.isConnected()){
    connectToWiFi();
  }
  if (millis() - previousMillis1 >= 1000) {
    previousMillis1 = millis();
    display.clearDisplay();
    time_t now = time(nullptr);
    struct tm* p_tm = localtime(&now);
    display.setTextSize(1);             // Normal 2:2 pixel scale
    display.setTextColor(SH110X_WHITE);        // Draw white text
    display.setCursor(10,0);
    display.setTextSize(4);             // Normal 2:2 pixel scale
    display.setTextColor(SH110X_WHITE);        // Draw white text
    display.setCursor(0,21);
    if ((p_tm->tm_hour)<10) {display.print("0");display.print(p_tm->tm_hour);}
    else display.print(p_tm->tm_hour);
    display.print(":");
    if ((p_tm->tm_min)<10) {display.print("0");display.println(p_tm->tm_min);}
    else display.println(p_tm->tm_min);
    display.display();
  }

  if (millis() - previousMillis2 >= 15000) {
    previousMillis2 = millis();
    OldCardID="";
  }
  delay(50);
  String CardID ="";
  for (uint8_t RF_Reader = 0; RF_Reader < RFID_Readers; RF_Reader++) {
    if(mfrc522[RF_Reader].PICC_IsNewCardPresent() && mfrc522[RF_Reader].PICC_ReadCardSerial()) {
      Serial.print(F("RF Reader "));
      Serial.print(RF_Reader);
      Serial.print(F(": Card UID:"));
      dump_byte_array(mfrc522[RF_Reader].uid.uidByte, mfrc522[RF_Reader].uid.size);
      Serial.println();
      Serial.print(F("PICC type: "));
      MFRC522::PICC_Type piccType = mfrc522[RF_Reader].PICC_GetType(mfrc522[RF_Reader].uid.sak);
      Serial.println(mfrc522[RF_Reader].PICC_GetTypeName(piccType));
      
      for(byte i = 0; i < mfrc522[RF_Reader].uid.size; i++){
        CardID += mfrc522[RF_Reader].uid.uidByte[i];
      }
      mfrc522[RF_Reader].PICC_HaltA();
      mfrc522[RF_Reader].PCD_StopCrypto1();
      
      if(CardID == OldCardID ){
        return;
      }
      else{
        OldCardID = CardID;
      }
      SendCardID(CardID);
      CardID = "";
    } 
  }
}

